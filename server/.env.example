# Postgres-verbinding (verplicht).
DATABASE_URL=postgres://scooternav:WACHTWOORD@localhost:5432/scooternav

# Poort waarop de API luistert.
PORT=8080

# CORS: alleen jouw frontend mag de API aanroepen. Komma-gescheiden voor meerdere.
# Leeg laten = alles toestaan (alleen voor lokaal ontwikkelen!).
CORS_ORIGIN=https://jouwapp.netlify.app

# Google OAuth client-id (WEB) — voor "Inloggen met Google". MOET gelijk zijn aan
# VITE_GOOGLE_CLIENT_ID in de frontend. Zie server/README.md "Auth".
# Zolang dit leeg is, zijn schrijf-acties uitgeschakeld (503).
GOOGLE_CLIENT_ID=
