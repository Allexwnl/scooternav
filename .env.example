# Kaartstijl. Leeg laten = keyless OpenFreeMap (geen account nodig).
# Wil je MapTiler? Zet hier je style-URL incl. ?key=... :
VITE_MAP_STYLE_URL=

# Backend voor meldingen (Track B): mock | api
# mock = voorbeeldmeldingen rond Purmerend (geen server nodig).
# api = je eigen REST-server (zie server/ en HANDOVER.md).
# Wisselen tussen backends doe je HIER — de app verandert niet.
VITE_REPORTS_BACKEND=mock

# Valhalla routeserver. Leeg = dev-proxy naar de publieke FOSSGIS-instance.
# Later je eigen self-hosted Valhalla, bijv. https://routing.jouwdomein.nl
VITE_VALHALLA_URL=

# Eigen REST-API — alleen nodig als VITE_REPORTS_BACKEND=api. Bijv. https://api.jouwdomein.nl
VITE_API_URL=

# Google OAuth client-id (WEB) voor "Inloggen met Google".
# MOET gelijk zijn aan GOOGLE_CLIENT_ID op de server. Zie server/README.md "Auth".
VITE_GOOGLE_CLIENT_ID=1080951166319-t5246e0gia2bink9ca1efhmfsk0v4787.apps.googleusercontent.com
